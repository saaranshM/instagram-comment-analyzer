# Mode auto-detection priority:
#   1. If INSTAGRAM_ACCESS_TOKEN + INSTAGRAM_USER_ID are set → uses Graph API (free, recommended)
#   2. If APIFY_API_TOKEN is set → uses Apify scraper (free tier)
#   3. If neither → error

# For API mode (free — requires account owner's token from developers.facebook.com)
INSTAGRAM_ACCESS_TOKEN=your_access_token_here
INSTAGRAM_USER_ID=your_instagram_user_id_here

# For scrape mode (free tier — sign up at apify.com, no Instagram login needed)
APIFY_API_TOKEN=apify_api_XXXXXXXXXXXXXXXXXXXXX

# For faster HuggingFace model downloads (optional)
HF_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXX
