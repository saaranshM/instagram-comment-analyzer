# Instagram handle to analyze (required)
INSTAGRAM_HANDLE=your_instagram_handle

# === Authentication (set at least one) ===

# Option 1: Instagram Graph API (free, recommended — requires account owner's token)
# Get token: developers.facebook.com > Create App > Add Instagram > Generate Token
# Get user ID: curl "https://graph.instagram.com/me?fields=id&access_token=TOKEN"
INSTAGRAM_ACCESS_TOKEN=your_access_token_here
INSTAGRAM_USER_ID=your_instagram_user_id_here

# Option 2: Apify scraper (free tier — sign up at apify.com, no Instagram login needed)
APIFY_API_TOKEN=apify_api_XXXXXXXXXXXXXXXXXXXXX

# === Optional ===

# HuggingFace token for faster model downloads (only if not using bundled model)
HF_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXX
